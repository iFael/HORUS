# ============================================================
# HORUS - Configuração de Ambiente
# ============================================================

# Token do Portal da Transparência (obrigatório para API CGU)
# Obtenha em: https://portaldatransparencia.gov.br/api-de-dados/cadastrar-email
TRANSPARENCIA_API_TOKEN=seu_token_aqui

# Nível de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Diretório de dados (padrão: ./data)
DATA_DIR=./data

# Diretório de exportações (padrão: ./exports)
EXPORTS_DIR=./exports

# Cache TTL em dias (padrão: 30)
CACHE_TTL_DAYS=30

# Número de workers para ETL paralelo
ETL_WORKERS=4

# Porta do dashboard Streamlit
STREAMLIT_PORT=8501
